{
  "name": "@pokujs/monocart",
  "private": false,
  "version": "1.0.0",
  "description": "☔️ A Poku plugin for V8 code coverage.",
  "main": "./lib/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pokujs/monocart.git"
  },
  "homepage": "https://poku.io",
  "bugs": {
    "url": "https://github.com/pokujs/monocart/issues"
  },
  "author": "https://github.com/wellwelwel",
  "funding": {
    "type": "github",
    "url": "https://github.com/pokujs/monocart?sponsor=1"
  },
  "files": [
    "lib"
  ],
  "engines": {
    "node": ">=18.x.x"
  },
  "scripts": {
    "pretest": "npm run build",
    "test": "poku test/e2e",
    "prebuild": "rm -rf lib",
    "build": "tsc",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .github/workflows/*.yml .",
    "update": "pu minor && npm i && (npm audit fix || true)",
    "postupdate": "npm run lint:fix"
  },
  "dependencies": {
    "jsonc.min": "^1.1.2",
    "monocart-coverage-reports": "^2.12.9",
    "toml.min": "^1.0.0",
    "yaml.min": "^0.1.0"
  },
  "peerDependencies": {
    "poku": "^4.1.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^25.5.0",
    "packages-update": "^2.0.0",
    "poku": "^4.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "🐷",
    "poku",
    "pokujs",
    "testing",
    "plugin",
    "coverage",
    "v8",
    "istanbul",
    "monocart",
    "monocart-coverage-reports",
    "codecov"
  ]
}
